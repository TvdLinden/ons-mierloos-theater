# Database Configuration
# For local development: use localhost
# For production (docker-compose.prod.yml): use the service name as host (db)
DATABASE_URL=postgresql://theater:password@db:5432/theater

# PostgreSQL container credentials (used by docker-compose.prod.yml)
POSTGRES_DB=theater
POSTGRES_USER=theater
POSTGRES_PASSWORD=change-me-in-production

# NextAuth Configuration
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Mollie Payment Configuration
MOLLIE_API_KEY=test_your_mollie_api_key_here
MOLLIE_WEBHOOK_URL=http://localhost:3000/api/mollie/webhook
# Set to 'true' for development without real Mollie payments
USE_MOCK_PAYMENT=false

# Email (SMTP) Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
FROM_EMAIL=info@onsmierloostheater.nl
FROM_NAME=Ons Mierloos Theater

R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_IMAGES_BUCKET_NAME=ons-mierloos-theater-images
# Optional: set to 'eu' for EU data residency endpoint
# R2_JURISDICTION=eu

# Application URLs (for emails)
APP_URL=http://localhost:3000

APP_ID=your-client-id-here