FROM node:20-alpine
WORKDIR /app

# Copy workspace package manifests (all three needed for npm ci)
COPY package.json package-lock.json ./
COPY shared/package.json shared/
COPY web/package.json web/
COPY worker/package.json worker/

RUN npm ci --omit=dev

# Copy shared source and pre-built migration SQL files
COPY shared/lib shared/lib
COPY shared/drizzle shared/drizzle

# Copy worker source
COPY worker worker

# Port for health checks
EXPOSE 8080

# Run from worker dir so tsx picks up worker/tsconfig.json (which has @/* path alias)
WORKDIR /app/worker

# tsx is in worker/dependencies; env vars injected by the runtime
CMD ["node", "--import", "tsx", "scripts/start-worker.ts"]
